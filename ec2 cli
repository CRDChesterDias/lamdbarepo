Write-Output "ec2name,ami"

$instances = aws ec2 describe-instances --region $region | ConvertFrom-Json

foreach ($reservation in $instances.Reservations) {
    foreach ($instance in $reservation.Instances) {
        $name = ($instance.Tags | Where-Object {$_.Key -eq "Name"}).Value
        $ami = aws ec2 describe-images --region $region --image-ids $instance.ImageId | ConvertFrom-Json

        Write-Output "$name,$($ami.Images[0].Name)"
    }
}
